# XLayer AI Configuration
# Copy this file to .env and configure your settings

# Debug mode
XLAYER_DEBUG=false
XLAYER_VERBOSE=true

# LLM Configuration
XLAYER_LLM__PROVIDER=openai
XLAYER_LLM__API_KEY=your-api-key-here
XLAYER_LLM__MODEL=gpt-4o-mini
XLAYER_LLM__TEMPERATURE=0.1
XLAYER_LLM__MAX_TOKENS=4096

# For Ollama (local LLM)
# XLAYER_LLM__PROVIDER=ollama
# XLAYER_LLM__BASE_URL=http://localhost:11434
# XLAYER_LLM__MODEL=llama2

# Scan Settings
XLAYER_SCAN__MAX_DEPTH=3
XLAYER_SCAN__MAX_PAGES=100
XLAYER_SCAN__TIMEOUT=30
XLAYER_SCAN__RATE_LIMIT=0.5
XLAYER_SCAN__USER_AGENT=XLayer-AI/1.0 (Security Scanner)
XLAYER_SCAN__VERIFY_SSL=true

# Port Scan Settings
XLAYER_PORT_SCAN__ENABLED=true
XLAYER_PORT_SCAN__TOP_PORTS=100
XLAYER_PORT_SCAN__TIMEOUT=2.0

# Exploit Settings
XLAYER_EXPLOIT__ENABLED=true
XLAYER_EXPLOIT__BROWSER_TIMEOUT=30
XLAYER_EXPLOIT__SCREENSHOT=true
XLAYER_EXPLOIT__MAX_ATTEMPTS=3

# Report Settings
XLAYER_REPORT__OUTPUT_DIR=./reports
XLAYER_REPORT__FORMATS=json,html
XLAYER_REPORT__INCLUDE_EVIDENCE=true

# Enabled Hunters (comma-separated)
XLAYER_HUNTERS=sqli,xss,auth,ssrf,lfi
